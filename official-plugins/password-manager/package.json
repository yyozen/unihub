{
  "name": "password-manager-plugin",
  "version": "1.0.0",
  "description": "密码管理器 - 安全存储和管理密码，支持密码生成和分类管理",
  "author": {
    "name": "UniHub Team",
    "email": "team@unihub.dev",
    "url": "https://github.com/unihub"
  },
  "keywords": [
    "password",
    "manager",
    "security",
    "encryption",
    "密码管理",
    "密码生成器",
    "安全"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package": "node scripts/package.js"
  },
  "unihub": {
    "id": "com.unihub.password-manager",
    "name": "密码管理器",
    "icon": "https://api.iconify.design/fluent-emoji/locked-with-key.svg",
    "category": "tool",
    "permissions": [
      "clipboard",
      "storage"
    ],
    "entry": "index.html"
  },
  "dependencies": {
    "@vueuse/core": "^14.1.0",
    "lucide-vue-next": "^0.562.0",
    "radix-vue": "^1.9.17",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@unocss/reset": "^0.65.3",
    "archiver": "^7.0.1",
    "typescript": "^5.7.3",
    "unocss": "^0.65.3",
    "vite": "^6.0.3"
  }
}
